{
  "name": "less-note",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "dev:desktop": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "npm run build && npm run start",
    "start": "node server/index.js",
    "desktop:dev": "set VITE_ENABLE_AUTH=false&& set CARGO_TARGET_DIR=%cd%\\.cargo-target&& tauri dev",
    "desktop:build": "set VITE_ENABLE_AUTH=false&& powershell -ExecutionPolicy Bypass -File ./scripts/desktop-build.ps1",
    "desktop:build:msi": "set VITE_ENABLE_AUTH=false&& powershell -ExecutionPolicy Bypass -File ./scripts/tauri-bundle.ps1 -BundleType msi",
    "desktop:build:nsis": "set VITE_ENABLE_AUTH=false&& powershell -ExecutionPolicy Bypass -File ./scripts/tauri-bundle.ps1 -BundleType nsis",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "better-auth": "^1.6.19",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "pg": "^8.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
