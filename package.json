{
  "name": "less-note",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop:dev": "set CARGO_TARGET_DIR=%cd%\\.cargo-target&& tauri dev",
    "desktop:build": "powershell -ExecutionPolicy Bypass -File ./scripts/desktop-build.ps1",
    "desktop:build:msi": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-bundle.ps1 -BundleType msi",
    "desktop:build:nsis": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-bundle.ps1 -BundleType nsis",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "mammoth": "^1.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
