{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LESS-NOTE",
  "version": "0.1.1",
  "identifier": "com.lessnote.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:4173",
    "beforeDevCommand": "npm run dev:desktop",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LESS-NOTE",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
